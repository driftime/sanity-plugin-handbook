{
  "name": "@driftime/sanity-plugin-handbook",
  "version": "0.2.0",
  "description": "Schema-driven documentation and editorial guides, built right into Sanity Studio.",
  "keywords": [
    "sanity",
    "sanity-plugin"
  ],
  "homepage": "https://github.com/driftime/sanity-plugin-handbook",
  "bugs": {
    "url": "https://github.com/driftime/sanity-plugin-handbook/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Kenny Heard",
    "email": "kenny@driftime.com",
    "url": "https://driftime.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/driftime/sanity-plugin-handbook.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "check": "oxfmt --check && oxlint",
    "fix": "oxfmt && oxlint --fix",
    "dev": "plugin-kit link-watch",
    "watch": "pkg-utils watch --strict",
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --clean --check"
  },
  "devDependencies": {
    "@sanity/browserslist-config": "1.0.5",
    "@sanity/pkg-utils": "10.4.13",
    "@sanity/plugin-kit": "4.0.20",
    "@sanity/ui": "3.1.14",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "5.20.0",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "@sanity/ui": "2 || 3",
    "react": "18 || 19",
    "sanity": "3 || 4 || 5"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "engines": {
    "node": ">=18"
  },
  "sanityPlugin": {
    "verifyPackage": {
      "sanityV2Json": false,
      "eslintImports": false,
      "scripts": false
    }
  },
  "dependencies": {
    "@driftime/sanity-plugin-handbook": "file:.yalc/@driftime/sanity-plugin-handbook"
  }
}
